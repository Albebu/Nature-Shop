{
  "name": "@ecommerce/email-service",
  "version": "0.0.0",
  "description": "Email notification microservice",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch --conditions=development src/index.ts | pino-pretty",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "author": "Albebu",
  "license": "ISC",
  "dependencies": {
    "@ecommerce/shared": "workspace:*",
    "amqplib": "^0.10.7",
    "dotenv": "^17.3.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "resend": "^6.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.7",
    "@types/node": "^22.19.11",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  }
}
